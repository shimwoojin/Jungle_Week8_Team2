body {
    width: 100%;
    height: 100%;
    margin: 0px;
    padding: 0px;
    font-family: "Malgun Gothic";
    color: white;
}

button {
    width: 220px;
    height: 38px;
    margin: 6px auto;
    display: block;
    background-color: rgb(46, 59, 76);
    color: white;
    font-size: 16px;
    border-width: 1px;
    border-color: rgb(72, 86, 108);
}

button:hover {
    background-color: rgb(72, 112, 166);
}

button:active {
    background-color: rgb(52, 92, 146);
}
