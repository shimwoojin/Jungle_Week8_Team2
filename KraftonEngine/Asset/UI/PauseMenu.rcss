#dim {
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 145);
    display: flex;
    align-items: center;
    justify-content: center;
}

#panel {
    width: 320px;
    padding: 24px;
    background-color: rgb(20, 23, 28);
    border-width: 1px;
    border-color: rgb(56, 64, 76);
}

#options-panel {
    display: none;
}

h1 {
    text-align: center;
    margin-bottom: 18px;
    font-size: 22px;
}
